<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#1F1F2A">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/ivProduct"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/wallet"/>

        <!-- Trash Icon -->
        <ImageView
            android:id="@+id/ivDelete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_delete"
            android:layout_alignParentEnd="true"/>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minimalist Leather Wallet"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_toEndOf="@id/ivProduct"
            android:layout_marginStart="12dp"/>

        <!-- Brand -->
        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LeatherCraft"
            android:textColor="#B0B0C0"
            android:textSize="12sp"
            android:layout_below="@id/tvName"
            android:layout_toEndOf="@id/ivProduct"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"/>

        <!-- Price -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$49.99"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_below="@id/tvBrand"
            android:layout_toEndOf="@id/ivProduct"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"/>

        <!-- Date Added -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Added on Jan 4, 2026"
            android:textColor="#B0B0C0"
            android:textSize="12sp"
            android:layout_below="@id/tvPrice"
            android:layout_toEndOf="@id/ivProduct"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"/>

        <!-- Add to Cart -->
        <ImageView
            android:id="@+id/ivAddToCart"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_add"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"/>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
